# Copia a .env.local y rellena. NO comitear valores reales.
# .env.local está en .gitignore — nunca se versiona.
#
# Supabase → Project Settings → API:
#   NEXT_PUBLIC_SUPABASE_URL       = "Project URL"        (https://<ref>.supabase.co)
#   NEXT_PUBLIC_SUPABASE_ANON_KEY  = "Project API keys → anon / public"
# ⚠️ NUNCA pongas aquí la service_role: es pública (llega al navegador) por el prefijo NEXT_PUBLIC_.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Servidor (SOLO backend / API routes — nunca expuesta al front):
ANTHROPIC_API_KEY=

# Gate de acceso: contraseña compartida del equipo. El middleware la exige antes de
# mostrar cualquier página. En local, si la dejas vacía el gate queda ABIERTO (dev).
# En Vercel es OBLIGATORIA. NO la commitees con valor real.
DASHBOARD_PASSWORD=

# Rate limit del chat de IA (/api/ask). Opcionales; defaults: 15 preguntas / 60 min por IP.
ASK_RATE_LIMIT_MAX=
ASK_RATE_LIMIT_WINDOW_MIN=
